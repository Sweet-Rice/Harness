# Safe template for local runtime configuration.
# Copy this file to `.env` and fill in the values for your environment.

# Ollama / model routing.
HARNESS_PROVIDER=ollama
HARNESS_MODEL=qwen3.5:latest
HARNESS_MODEL_ORCHESTRATOR=qwen3.5:latest
HARNESS_MODEL_DELEGATE=qwen3.5:latest
HARNESS_MODEL_CHAT=gemma4:latest
OLLAMA_HOST=http://127.0.0.1:11434

# MCP deployment. Point HARNESS_MCP_URL at the machine that hosts the MCP server.
HARNESS_MCP_HOST=0.0.0.0
HARNESS_MCP_PORT=8000
HARNESS_MCP_URL=http://127.0.0.1:8000/mcp

# Web interface network settings.
HARNESS_WEB_HOST=0.0.0.0
HARNESS_WEB_HTTP_PORT=8765
HARNESS_WEB_WS_HOST=0.0.0.0
HARNESS_WEB_WS_PORT=8766
# Optional explicit public websocket URL for browser clients behind proxies/NAT.
# HARNESS_WEB_WS_URL=ws://your-public-host:8766

# Shared persistence path.
HARNESS_DB_PATH=./harness/jarvis.db

# Core runtime limits.
HARNESS_MAX_LOOP_ROUNDS=15
HARNESS_MAX_DELEGATE_ROUNDS=10
HARNESS_MAX_CONTEXT_MESSAGES=20
HARNESS_THINK=false

# Discord interface settings.
# Leave blank if you are not using the Discord bot.
HARNESS_DISCORD_TOKEN=
HARNESS_DISCORD_COMMAND_PREFIX=!
HARNESS_DISCORD_EDIT_INTERVAL=2.0
# Discord is default-deny for both MCP tools and orchestration pseudo-tools.
# Add comma-separated tool names here only if you explicitly want them exposed.
HARNESS_DISCORD_TOOL_ALLOWLIST=
